{
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "Audit-Missing-Tags-on-resource-groups",
  "properties": {
    "displayName": "Audit missing tags on resource groups",
    "mode": "All",
    "description": "Audit existence of tags on resource groups.",
    "parameters": {
      "tagName": {
        "type": "String",
        "metadata": {
          "displayName": "Tag Name",
          "description": "Name of the tag, such as 'Region'"
        }
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Resources/subscriptions/resourceGroups"
          },
          {
            "field": "[concat('tags[', parameters('tagName'), ']')]",
            "exists": "false"
          }
        ]
      },
      "then": {
        "effect": "Deny"
      }
    }
  }
}